<Window x:Class="BargainVault.Views.FacebookPostsListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Facebook Posts"
        Width="900"
        Height="500"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>

        <Style x:Key="MainMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                       x:Name="border"
                       Background="{TemplateBinding Background}"
                       BorderBrush="{TemplateBinding BorderBrush}"
                       BorderThickness="{TemplateBinding BorderThickness}"
                       CornerRadius="6">

                            <ContentPresenter
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Visual states -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#D6D6D6"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#C8C8C8"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#EEEEEE"/>
                                <Setter Property="Foreground"
                                   Value="#888888"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,8">
            <TextBlock Text="🔍 Search:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>
            <TextBox Width="260"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Active Listings:"
               VerticalAlignment="Center"
               FontWeight="SemiBold"
               Margin="10,0,4,0"/>

            <TextBlock Text="{Binding ActiveCount}"
               VerticalAlignment="Center"
               FontWeight="Bold"/>
        </StackPanel>

        <!-- Grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding PostsView}"
                  SelectedItem="{Binding SelectedPost}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="EditSelected_Click">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Post ID"
                                    Binding="{Binding PostId}"
                                    Width="80"/>
                <DataGridTextColumn Header="Item"
                                    Binding="{Binding ItemTitle}"
                                    Width="*"/>
                <DataGridTextColumn Header="Post Date"
                                    Binding="{Binding PostDate, StringFormat=d}"
                                    Width="120"/>
                <DataGridTextColumn Header="Price"
                                    Binding="{Binding AskingPrice, StringFormat=C}"
                                    Width="120"/>
                <DataGridCheckBoxColumn Header="Boosted"
                                        Binding="{Binding Boosted}"
                                        Width="90"/>
                <DataGridCheckBoxColumn Header="Sold"
                                        Binding="{Binding MarkAsSold}"
                                        Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Content="✏️ Edit"
                    Style="{StaticResource MainMenuButtonStyle}"
                    IsEnabled="{Binding HasSelection}"
                    Click="EditSelected_Click"/>

            <Button Content="🗑 Delete"
                    Style="{StaticResource MainMenuButtonStyle}"
                    IsEnabled="{Binding HasSelection}"
                    Click="DeleteSelected_Click"/>

            <Button Content="Close"
                    Style="{StaticResource MainMenuButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
