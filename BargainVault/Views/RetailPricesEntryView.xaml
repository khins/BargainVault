<Window x:Class="BargainVault.Views.RetailPricesEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retail Price Entry"
        Width="520"
        Height="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>

        <Style x:Key="MainMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                       x:Name="border"
                       Background="{TemplateBinding Background}"
                       BorderBrush="{TemplateBinding BorderBrush}"
                       BorderThickness="{TemplateBinding BorderThickness}"
                       CornerRadius="6">

                            <ContentPresenter
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Visual states -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#D6D6D6"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#C8C8C8"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#EEEEEE"/>
                                <Setter Property="Foreground"
                                   Value="#888888"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Retail Price Entry"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Item -->
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Item:"
                           VerticalAlignment="Center"
                           Margin="0,6"/>
                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          ItemsSource="{Binding Items}"
                          DisplayMemberPath="Title"
                          SelectedValuePath="ItemId"
                          SelectedValue="{Binding SelectedItemId}"
                          Margin="4"/>

                <!-- Store -->
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Store:"
                           VerticalAlignment="Center"
                           Margin="0,6"/>
                <ComboBox Grid.Row="1"
                          Grid.Column="1"
                          ItemsSource="{Binding Stores}"
                          DisplayMemberPath="StoreName"
                          SelectedValuePath="StoreId"
                          SelectedValue="{Binding SelectedStoreId}"
                          Margin="4"/>

                <!-- Retail Price -->
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Retail Price:"
                           VerticalAlignment="Center"
                           Margin="0,6"/>
                <TextBox Grid.Row="2"
                           Grid.Column="1"
                            Text="{Binding RetailPrice,
                           Mode=TwoWay,
                           UpdateSourceTrigger=LostFocus,
                           StringFormat={}{0:C2}}"
                            Margin="1,4,210,4"
                            Width="130"/>

                <!-- Price Date -->
                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="Price Date:"
                           VerticalAlignment="Center"
                           Margin="0,6"/>
                <DatePicker Grid.Row="3"
                            Grid.Column="1"
                            SelectedDate="{Binding PriceDate}"
                            Margin="4"/>

                <!-- Sale Flag -->
                <CheckBox Grid.Row="4"
                          Grid.Column="1"
                          Content="Sale Price"
                          IsChecked="{Binding IsSalePrice}"
                          Margin="4"/>

                <!-- Notes -->
                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Text="Notes:"
                           VerticalAlignment="Top"
                           Margin="0,6"/>
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Text="{Binding Notes}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="70"
                         Margin="4"/>
            </Grid>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Save"
Style="{StaticResource MainMenuButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsDirty}"/>

            <Button Content="Close"
Style="{StaticResource MainMenuButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
