<Window x:Class="BargainVault.Views.InventoryLocationsEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory Location Entry"
        Height="520"
        Width="620"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FORM -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title / Item -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Title:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding Items}"
                      DisplayMemberPath="Title"
                      SelectedValuePath="ItemId"
                      SelectedValue="{Binding SelectedItemId}"
                      Margin="4"/>

            <!-- Channel -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Channel Type:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding ChannelTypes}"
                      SelectedItem="{Binding SelectedChannelType}"
                      Margin="4"/>

            <!-- Status -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Status:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1"
                      ItemsSource="{Binding Statuses}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding SelectedStatusId}"
                      Margin="4"/>

            <!-- Date Placed -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Date Placed:" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="3" Grid.Column="1"
                        SelectedDate="{Binding DatePlaced}"
                        Margin="4"/>

            <!-- Price -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Price:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     Text="{Binding AskingPrice, UpdateSourceTrigger=PropertyChanged}"
                     Margin="4"/>

            <!-- Notes -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Notes:" VerticalAlignment="Top"/>
            <TextBox Grid.Row="5" Grid.Column="1"
                     Text="{Binding Notes}"
                     AcceptsReturn="True"
                     Height="80"
                     TextWrapping="Wrap"
                     Margin="4"/>

            <!-- Created -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Created_at:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="6" Grid.Column="1"
                     Text="{Binding CreatedAt}"
                     IsReadOnly="True"
                     Margin="4"/>
        </Grid>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,12,0,0">

            <Button Content="💾 Save"
                    Width="100"
                    Margin="6,0"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsDirty}"/>
                    

            <Button Content="New Entry"
                    Width="110"
                    Margin="6,0"
                    Command="{Binding NewCommand}"/>

            <Button Content="Close"
                    Width="110"
                    Margin="6,0"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
