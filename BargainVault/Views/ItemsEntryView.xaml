<Window x:Class="BargainVault.Views.Items.ItemsEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Entry"
        Width="500"
        Height="350"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Lot Number -->
        <TextBlock Text="Lot Number" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Text="{Binding LotNumber}" Grid.Row="0" Grid.Column="1"/>

        <!-- Title -->
        <TextBlock Text="Title" Grid.Row="1" Grid.Column="0" Margin="0,10,0,0"/>
        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"/>

        <!-- Description -->
        <TextBlock Text="Description" Grid.Row="2" Grid.Column="0" Margin="0,10,0,0"/>
        <TextBox Text="{Binding Description}"
                 Grid.Row="2" Grid.Column="1"
                 Height="80"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Margin="0,10,0,0"/>

        <!-- Created At -->
        <TextBlock Text="Created At" Grid.Row="3" Grid.Column="0" Margin="0,10,0,0"/>
        <TextBox Text="{Binding CreatedAt, Mode=OneWay, StringFormat=\{0:G\}}"
                 Grid.Row="3" Grid.Column="1"
                 IsReadOnly="True"
                 Margin="0,10,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button Content="Save Entry"
                    Width="100"
                    Margin="5"
                    Command="{Binding SaveCommand}" />

            <Button Content="New Entry"
                    Width="100"
                    Margin="5"
                    Command="{Binding NewEntryCommand}"/>

            <Button Content="Close"
                    Width="100"
                    Margin="5"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
