<Window x:Class="BargainVault.Views.ItemsEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Entry"
        Width="820"
        Height="660"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>

        <Style x:Key="MainMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#D6D6D6"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#C8C8C8"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#EEEEEE"/>
                                <Setter Property="Foreground"
                                        Value="#888888"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- HEADER -->
        <!-- ========================= -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="Item Entry"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBlock Text=" — "
                       FontSize="22"
                       Margin="6,0"/>

            <TextBlock Text="{Binding ItemId, StringFormat=Item \#{0}}"
                       FontSize="16"
                       Foreground="Gray"
                       VerticalAlignment="Bottom"/>
        </StackPanel>

        <!-- ========================= -->
        <!-- MAIN CONTENT -->
        <!-- ========================= -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE - ITEM DATA -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="Auto"/>
                    <!-- Lot -->
                    <RowDefinition Height="Auto"/>
                    <!-- Description -->
                    <RowDefinition Height="Auto"/>
                    <!-- Created -->
                    <RowDefinition Height="*"/>
                    <!-- Spacer -->
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Title" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Title}"
                             Margin="0,4,0,12"
                             Height="28"/>
                </StackPanel>

                <!-- Lot Number -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Lot Number" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding LotNumber}"
                             Margin="0,4,0,12"
                             Height="28"/>
                </StackPanel>

                <!-- Description -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Description" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Description}"
                             Margin="0,4,0,8"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Height="200"/>
                </StackPanel>

                <!-- ✅ CREATED DATE (new section) -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Created"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CreatedAtDisplay}"
                               Foreground="Gray"
                               Margin="0,4,0,0"/>
                </StackPanel>

            </Grid>

            <!-- RIGHT SIDE - IMAGE -->
            <Border Grid.Column="2"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Background="#FAFAFA">

                <StackPanel>
                    <TextBlock Text="Item Image"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Border BorderBrush="#CCC"
                            BorderThickness="1"
                            Height="260"
                            Background="White"
                            CornerRadius="4">

                        <Image Source="{Binding ItemImage}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <Button Content="Select Image"
                            Style="{StaticResource MainMenuButtonStyle}"
                            Command="{Binding SelectImageCommand}"/>
                </StackPanel>

            </Border>
        </Grid>

        <!-- ========================= -->
        <!-- BUTTONS -->
        <!-- ========================= -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Save"
                    Style="{StaticResource MainMenuButtonStyle}"
                    Command="{Binding SaveCommand}"/>

            <Button Content="Close"
                    Style="{StaticResource MainMenuButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>

    </Grid>
</Window>
