<Window x:Class="BargainVault.Views.SalesDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sales Dashboard"
        Width="800"
        Height="480"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="📊 Monthly Sales Summary"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding MonthlySales}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="DashboardGrid_DoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Year"
                                    Binding="{Binding Year}"
                                    Width="80"/>

                <DataGridTextColumn Header="Month"
                                    Binding="{Binding Month}"
                                    Width="80"/>

                <DataGridTextColumn Header="Total Sales"
                                    Binding="{Binding TotalSales, StringFormat=C}"
                                    Width="*"/>

                <DataGridTextColumn Header="Qty Sold"
                                    Binding="{Binding TotalQuantity}"
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer / Close -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">

            <Button Content="Close"
                    Width="100"
                    IsCancel="True"
                    Click="Close"/>
        </StackPanel>
    </Grid>
</Window>
