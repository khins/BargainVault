<Window x:Class="BargainVault.Views.Acquisitions.AcquisitionsListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acquisitions"
        Width="900"
        Height="560"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>

        <Style x:Key="MainMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                       x:Name="border"
                       Background="{TemplateBinding Background}"
                       BorderBrush="{TemplateBinding BorderBrush}"
                       BorderThickness="{TemplateBinding BorderThickness}"
                       CornerRadius="6">

                            <ContentPresenter
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Visual states -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#D6D6D6"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#C8C8C8"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                   Property="Background"
                                   Value="#EEEEEE"/>
                                <Setter Property="Foreground"
                                   Value="#888888"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== FILTER BAR ===== -->
        <!-- ================= TOOLBAR ================= -->
        <Grid Margin="0,0,0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Search label -->
            <TextBlock Text="🔎 Search:"
               VerticalAlignment="Center"
               FontWeight="SemiBold"/>

            <!-- Search box -->
            <TextBox Grid.Column="1"
             Height="30"
             VerticalContentAlignment="Center"
             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Filter button -->
            <Button Grid.Column="3"
            Height="30"
            Content="📅 Filter Dates"
            Click="FilterDates_Click"
            Margin="0"/>

            <!-- Clear button -->
            <Button Grid.Column="5"
            Height="30"
            Content="✖ Clear Filter"
            Click="ClearFilter_Click"
            Margin="0"/>

            <!-- Filter status text -->
            <TextBlock Grid.Column="6"
               Margin="14,0,0,0"
               VerticalAlignment="Center"
               Foreground="Gray"
               FontStyle="Italic"
               Text="{Binding FilterStatusText}"/>

        </Grid>


        <!-- ===== DATA GRID ===== -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ItemsView}"
                  SelectedItem="{Binding SelectedAcquisition}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="EditSelected_Click">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding AcqId}"
                                    Width="60"/>

                <DataGridTextColumn Header="Item"
                                    Binding="{Binding ItemTitle}"
                                    Width="220"/>

                <DataGridTextColumn Header="Date"
                                    Binding="{Binding DateAcquired, StringFormat=d}"
                                    Width="120"/>

                <DataGridTextColumn Header="Total"
                                    Binding="{Binding TotalSettlement, StringFormat=C}"
                                    Width="120"/>

                <DataGridTextColumn Header="Status"
                                    Binding="{Binding StatusName}"
                                    Width="140"/>

                <DataGridCheckBoxColumn Header="Personal"
                                        Binding="{Binding Personal}"
                                        Width="90"
                                        IsReadOnly="True"/>

                <DataGridCheckBoxColumn Header="Business"
                                        Binding="{Binding BusinessExpense}"
                                        Width="90"
                                        IsReadOnly="True"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- ===== TOTALS FOOTER ===== -->
        <Border Grid.Row="2"
                Background="#F2F2F2"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                Padding="6">

            <DockPanel>

                <!-- ========================= -->
                <!-- FOOTER -->
                <!-- ========================= -->
                <Grid Grid.Row="4" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: TOTAL -->
                    <TextBlock Grid.Column="0"
               VerticalAlignment="Center"
               FontWeight="SemiBold"
               FontSize="14"
               Text="{Binding TotalSettlement, StringFormat=Total Settlement: {0:C}}"/>

                    <!-- RIGHT: BUTTONS -->
                    <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                        <Button Content="Edit"
Style="{StaticResource MainMenuButtonStyle}"
                Click="EditSelected_Click"/>

                        <Button Content="Delete"
Style="{StaticResource MainMenuButtonStyle}"
                Click="DeleteSelected_Click"/>

                        <Button Content="Close"
Style="{StaticResource MainMenuButtonStyle}"
                IsCancel="True"/>
                    </StackPanel>
                </Grid>


            </DockPanel>
        </Border>

    </Grid>
</Window>
