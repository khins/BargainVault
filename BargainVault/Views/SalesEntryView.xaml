<Window x:Class="BargainVault.Views.SalesEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sales Entry"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="💰 Sales Entry"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- Form -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Item -->
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Item ID:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  ItemsSource="{Binding Items}"
                  SelectedValuePath="ItemId"
                  DisplayMemberPath="Title"
                  SelectedValue="{Binding SelectedItemId, Mode=TwoWay}"
                  Margin="0,4"
                  IsEditable="True"
                  IsTextSearchEnabled="True"/>

            <!-- Date Sold -->
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Date Sold:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <DatePicker Grid.Row="1"
                        Grid.Column="1"
                        SelectedDate="{Binding DateSold}"
                        Margin="0,4"/>

            <!-- Quantity -->
            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Qty Sold:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="2"
                     Grid.Column="1"
                     Text="{Binding QtySold}"
                     Margin="0,4"/>

            <!-- Channel -->
            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="Channel:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="3"
                     Grid.Column="1"
                     Text="{Binding ChannelType}"
                     Margin="0,4"/>

            <!-- Booth -->
            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Booth ID:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="4"
                     Grid.Column="1"
                     Text="{Binding BoothId}"
                     Margin="0,4"/>

            <!-- Unit Price -->
            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Text="Unit Price:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="5"
                     Grid.Column="1"
                     Text="{Binding UnitSalePrice}"
                     Margin="0,4"/>

            <!-- Discount -->
            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Text="Discount:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="6"
                     Grid.Column="1"
                     Text="{Binding DiscountedRate}"
                     Margin="0,4"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="💾 Save"
                    Width="100"
                    Margin="6,0"
                    Command="{Binding SaveCommand}"/>

            <Button Content="Close"
                    Width="100"
                    Margin="6,0"
                    Click="Close"/>
        </StackPanel>
    </Grid>
</Window>
