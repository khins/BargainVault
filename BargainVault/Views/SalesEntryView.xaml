<Window x:Class="BargainVault.Views.SalesEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sales Entry"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>

        <Style x:Key="MainMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                x:Name="border"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6">

                            <ContentPresenter
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Visual states -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                            Property="Background"
                            Value="#D6D6D6"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                            Property="Background"
                            Value="#C8C8C8"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                            Property="Background"
                            Value="#EEEEEE"/>
                                <Setter Property="Foreground"
                            Value="#888888"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="💰 Sales Entry"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- Form -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Item -->
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Item ID:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  ItemsSource="{Binding Items}"
                  SelectedValuePath="ItemId"
                  DisplayMemberPath="Title"
                  SelectedValue="{Binding SelectedItemId, Mode=TwoWay}"
                  Margin="0,4"
                  IsEditable="True"
                  IsTextSearchEnabled="True"/>

            <!-- Date Sold -->
            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Date Sold:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <DatePicker Grid.Row="1"
                        Grid.Column="1"
                        SelectedDate="{Binding DateSold}"
                        Margin="0,4"/>

            <!-- Quantity -->
            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="Qty Sold:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="2"
                     Grid.Column="1"
                     Text="{Binding QtySold}"
                     Margin="0,4"/>

            <!-- Channel -->
            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="Channel:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="3"
                     Grid.Column="1"
                     Text="{Binding ChannelType}"
                     Margin="0,4"/>

            <!-- Booth -->
            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Text="Booth ID:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <ComboBox Grid.Row="4"
                      Grid.Column="1"
                      ItemsSource="{Binding Booths}"
                      DisplayMemberPath="BoothName"
                      SelectedValuePath="BoothId"
                      SelectedValue="{Binding SelectedBoothId, Mode=TwoWay}"
                      Margin="0,4"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      ToolTip="Select booth"/>

            <!-- Unit Price -->
            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Text="Unit Price:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="5"
                     Grid.Column="1"
                     Text="{Binding UnitSalePrice}"
                     Margin="0,4"/>

            <!-- Discount -->
            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Text="Discount:"
                       VerticalAlignment="Center"
                       Margin="0,4"/>

            <TextBox Grid.Row="6"
                     Grid.Column="1"
                     Text="{Binding DiscountedRate}"
                     Margin="0,4"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="💾 Save"
                    Style="{StaticResource MainMenuButtonStyle}"
                    Command="{Binding SaveCommand}"/>

            <Button Content="Close"
                    Style="{StaticResource MainMenuButtonStyle}"
                    Click="Close"/>
        </StackPanel>
    </Grid>
</Window>
