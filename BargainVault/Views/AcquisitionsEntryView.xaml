<Window x:Class="BargainVault.Views.AcquisitionsEntryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acquisition Entry"
        Height="620"
        Width="700"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>

        <Style x:Key="MainMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">

                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Visual states -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                    Property="Background"
                                    Value="#D6D6D6"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                    Property="Background"
                                    Value="#C8C8C8"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                    Property="Background"
                                    Value="#EEEEEE"/>
                                <Setter Property="Foreground"
                                    Value="#888888"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>


    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- =========================
             HEADER
        ========================== -->
        <TextBlock Text="Acquisition Entry"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- =========================
             FORM BODY
        ========================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Item -->
            <TextBlock Text="Item"
                       Grid.Row="0"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Row="0"
                      Grid.Column="1"
                      ItemsSource="{Binding Items}"
                      DisplayMemberPath="Title"
                      SelectedValuePath="ItemId"
                      SelectedValue="{Binding SelectedItemId}"
                      Margin="4"/>

            <!-- Auction Site -->
            <TextBlock Text="Auction Site"
                       Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1"
                      Grid.Column="1"
                      ItemsSource="{Binding AuctionSites}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding SelectedAuctionSiteId}"
                      Margin="4"/>

            <!-- Status -->
            <TextBlock Text="Status"
                       Grid.Row="2"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2"
                      Grid.Column="1"
                      ItemsSource="{Binding Statuses}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding SelectedStatusId}"
                      Margin="4"/>

            <!-- Date Acquired -->
            <TextBlock Text="Date Acquired"
                       Grid.Row="3"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <DatePicker Grid.Row="3"
                        Grid.Column="1"
                        SelectedDate="{Binding DateAcquired}"
                        Margin="4"/>

            <!-- Quantity -->
            <TextBlock Text="Quantity"
                       Grid.Row="4"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="4"
                     Grid.Column="1"
                     Text="{Binding QtyAcquired}"
                     Margin="4"/>

            <!-- Unit Hammer Price -->
            <TextBlock Text="Unit Hammer Price"
                       Grid.Row="5"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="5"
                     Grid.Column="1"
                     Text="{Binding UnitHammerPrice}"
                     Margin="4"/>

            <!-- Buyer Premium -->
            <TextBlock Text="Buyer Premium"
                       Grid.Row="6"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="6"
                     Grid.Column="1"
                     Text="{Binding BuyerPremium}"
                     Margin="4"/>

            <!-- Tax Rate -->
            <TextBlock Text="Tax Rate"
                       Grid.Row="7"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="7"
                     Grid.Column="1"
                     Text="{Binding TaxRate}"
                     Margin="4"/>

            <!-- Sales Tax Paid (Read-only) -->
            <TextBlock Text="Sales Tax Paid"
                       Grid.Row="8"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="8"
                     Grid.Column="1"
                     Text="{Binding SalesTaxPaid, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="#EEE"
                     Margin="4"/>

            <!-- Total Settlement (Read-only) -->
            <TextBlock Text="Total Settlement"
                       Grid.Row="9"
                       Grid.Column="0"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="9"
                     Grid.Column="1"
                     Text="{Binding TotalSettlement, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="#EEE"
                     FontWeight="Bold"
                     Margin="4"/>

            <!-- Personal -->
            <CheckBox Content="Personal Purchase"
                      Grid.Row="10"
                      Grid.Column="1"
                      IsChecked="{Binding IsPersonal}"
                      Margin="4"/>

            <!-- Business Expense -->
            <CheckBox Content="Business Expense"
                      Grid.Row="11"
                      Grid.Column="1"
                      IsChecked="{Binding IsBusinessExpense}"
                      Margin="4"/>
        </Grid>

        <!-- =========================
             BUTTONS
        ========================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button Content="Save"
                    Style="{StaticResource MainMenuButtonStyle}"
                    Command="{Binding SaveCommand}"/>

            <Button Content="Close"
                    Style="{StaticResource MainMenuButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
