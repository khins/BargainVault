<Window x:Class="BargainVault.Views.RetailPricesListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retail Prices"
        Width="900"
        Height="550"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>

        <Style x:Key="MainMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#707070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">

                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Visual states -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                    Property="Background"
                                    Value="#D6D6D6"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                    Property="Background"
                                    Value="#C8C8C8"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                    Property="Background"
                                    Value="#EEEEEE"/>
                                <Setter Property="Foreground"
                                    Value="#888888"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <TextBlock Text="Retail Prices"
                   FontSize="22"
                   FontWeight="Bold"/>

        <!-- ================= TOOLBAR ================= -->
        <Grid Grid.Row="2" Margin="0,0,0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="🔎 Search:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>

            <TextBox Grid.Column="1"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="3"
                    Height="30"
                    Content="✏ Edit"
                    Click="EditSelected_Click"/>

            <Button Grid.Column="5"
                    Height="30"
                    Content="🗑 Delete"
                    Click="DeleteSelected_Click"
                    IsEnabled="{Binding HasSelection}"/>

            <TextBlock Grid.Column="6"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="Gray"
                       FontStyle="Italic"
                       Text="{Binding ActiveFilterText}"/>

        </Grid>

        <!-- ================= DATA GRID ================= -->
        <DataGrid Grid.Row="2"
                  Margin="0,36,0,0"
                  ItemsSource="{Binding ItemsView}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MouseDoubleClick="EditSelected_Click">

            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding RetailPriceId}"
                                    Width="70"/>

                <DataGridTextColumn Header="Item"
                                    Binding="{Binding ItemTitle}"
                                    Width="2*"/>

                <DataGridTextColumn Header="Store"
                                    Binding="{Binding StoreName}"
                                    Width="1.2*"/>

                <DataGridTextColumn Header="Price"
                                    Binding="{Binding RetailPrice, StringFormat=C}"
                                    Width="120"/>

                <DataGridTextColumn Header="Date"
                                    Binding="{Binding PriceDate, StringFormat=d}"
                                    Width="120"/>

                <DataGridCheckBoxColumn Header="Sale"
                                        Binding="{Binding IsSalePrice}"
                                        Width="80"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ================= BOTTOM BUTTONS ================= -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Close"
                    Style="{StaticResource MainMenuButtonStyle}"
                    IsCancel="True"/>
            <Button Content="✏ Edit"
                    Style="{StaticResource MainMenuButtonStyle}"
                    Click="EditSelected_Click"/>

            <Button Content="🗑 Delete"
                    Style="{StaticResource MainMenuButtonStyle}"
                    Click="DeleteSelected_Click"
                    IsEnabled="{Binding HasSelection}"/>
        </StackPanel>

    </Grid>
</Window>
