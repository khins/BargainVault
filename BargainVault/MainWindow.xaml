<Window x:Class="BargainVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BargainVault"
        Width="420"
        Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Border Padding="20"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="#DDD"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Width="220"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Logo -->
                <Image Source="pack://application:,,,/Assets/BargainVaultLogo.png"
                       Height="90"
                       Stretch="Uniform"
                       Margin="0,0,0,12"/>

                <!-- App Title -->
                <TextBlock Text="Bargain Vault"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                <!-- New Item Entry -->
                <Button Content="New Item Entry"
                        Height="40"
                        Margin="0,0,0,10"
                        Click="OpenItemsEntry_Click"/>

                <!-- Items List -->
                <Button Content="View / Edit Items"
                        Height="40"
                        Margin="0,0,0,10"
                        Click="OpenItemsList_Click"/>

                <Button Content="New Acquisition"
                        Width="160"
                        Height="40"
                        Margin="0,0,0,10"
                        Click="OpenAcquisitionEntry_Click"/>
                <Button Content="Acquisitions List"
                        Width="160"
                        Height="36"
                        Margin="4"
                        Click="OpenAcquisitionsList_Click"/>

                <!-- Exit -->
                <Button Content="Exit"
                        Height="36"
                        Margin="0,16,0,0"
                        Click="Exit_Click"/>


            </StackPanel>
        </Border>
    </Grid>
</Window>
